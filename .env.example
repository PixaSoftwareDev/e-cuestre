# ─────────────────────────────────────────────────────────────
# Ecuestre — variables de entorno (ejemplo). Copiá a .env y completá.
# ─────────────────────────────────────────────────────────────

# Base de datos (Postgres)
DATABASE_URL="postgresql://ecuestre:ecuestre@localhost:5435/ecuestre?schema=public"

# Admin (panel)
ADMIN_EMAIL="admin@ecuestre.com"
ADMIN_PASSWORD="cambiame123"
AUTH_SECRET="poné-una-cadena-larga-y-aleatoria"

# Sitio
NEXT_PUBLIC_SITE_NAME="Ecuestre"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Si se sirve bajo un subpath detrás de nginx (ej. /ecuestre), definilo acá:
NEXT_PUBLIC_BASE_PATH=""
# Grabación de sesiones (rrweb): "on" para activar
NEXT_PUBLIC_SESSION_RECORDING="on"
# Botón "acceso rápido" en el login (solo pruebas): "on" para mostrarlo
NEXT_PUBLIC_QUICK_LOGIN=""

# Puertos (Docker compose)
APP_PORT="3000"
DB_PORT="5435"

# ── PAGOS ────────────────────────────────────────────────────
# Elegí UNO (o ambos). Mientras estén vacíos, el checkout avisa que no hay
# medio de pago configurado.

# PayPal (internacional). PAYPAL_ENV: "sandbox" (pruebas) o "live" (real).
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
NEXT_PUBLIC_PAYPAL_CURRENCY="USD"

# Mercado Pago (Argentina). Access Token desde el panel de MP.
# Poné NEXT_PUBLIC_MP_ENABLED="true" para mostrar el botón.
MP_ACCESS_TOKEN=""
NEXT_PUBLIC_MP_ENABLED=""

# ── EMAILS (Resend) ──────────────────────────────────────────
# Mientras RESEND_API_KEY esté vacío, NO se envían emails (no rompe el checkout).
# Al cargar la key, salen solos: confirmación al cliente + aviso de venta al admin
# + aviso de envío al marcar la orden como "Enviada".
RESEND_API_KEY=""
# Remitente verificado en Resend, ej. "Ecuestre <ventas@tudominio.com>"
EMAIL_FROM=""
# A dónde te llegan los avisos de venta (si vacío, usa ADMIN_EMAIL)
ADMIN_NOTICE_EMAIL=""
