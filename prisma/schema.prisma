// Ecuestre — E-commerce premium multi-marca
// Base de datos: PostgreSQL · ORM: Prisma
// Precios siempre en la mínima unidad monetaria (centavos) para evitar errores de redondeo.

generator client {
  provider      = "prisma-client-js"
  // "native" = tu SO local (dev); el target musl es para el contenedor Alpine.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Catálogo
// ─────────────────────────────────────────────────────────────

/// Una marca / rubro. El campo `theme` guarda los design tokens
/// (colores, tipografías, radios) que adaptan el diseño a cada marca.
model Brand {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  tagline      String?
  description  String?
  logoUrl      String?
  heroImageUrl String?
  theme        Json? // { colors: {...}, fonts: {...}, radius: "..." }
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products   Product[]
  categories Category[]
}

model Category {
  id        String     @id @default(cuid())
  slug      String
  name      String
  imageUrl  String?
  brandId   String?
  brand     Brand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())

  products Product[]

  @@unique([brandId, slug])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  description     String?
  story           String? // copy largo / storytelling premium
  brandId         String
  brand           Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  basePrice       Int // centavos
  compareAtPrice  Int? // precio tachado
  currency        String        @default("USD")
  status          ProductStatus @default(DRAFT)
  featured        Boolean       @default(false)
  tags            String[]
  material        String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@index([brandId])
  @@index([status])
  @@index([featured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String  @unique
  name       String // ej. "Talle M / Negro"
  price      Int? // override en centavos; null => usa basePrice
  stock      Int     @default(0)
  attributes Json? // { talle: "M", color: "Negro" }
  sortOrder  Int     @default(0)

  orderItems OrderItem[]
}

// ─────────────────────────────────────────────────────────────
// Órdenes
// ─────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(cuid())
  number          String      @unique
  email           String
  customerName    String?
  phone           String?
  status          OrderStatus @default(PENDING)
  subtotal        Int
  shipping        Int         @default(0)
  tax             Int         @default(0)
  total           Int
  currency        String      @default("USD")
  paymentProvider String? // "paypal"
  paymentRef      String? // id de la orden/captura del proveedor
  shippingAddress Json?
  note            String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  name        String // snapshot del nombre al momento de la compra
  variantName String?
  imageUrl    String?
  unitPrice   Int
  quantity    Int
  lineTotal   Int
}

// ─────────────────────────────────────────────────────────────
// Administración
// ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Analítica (qué se vende / qué no) + grabación de sesión
// ─────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String // page_view | product_view | add_to_cart | begin_checkout | purchase | search
  sessionId String
  path      String?
  productId String?
  brandId   String?
  value     Int? // centavos involucrados
  quantity  Int?
  metadata  Json?
  referrer  String?
  device    String? // mobile | tablet | desktop
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([sessionId])
  @@index([productId])
}

/// Grabación de sesión (rrweb). Los eventos se guardan en chunks
/// para poder ir agregando sin reescribir toda la sesión.
model SessionRecording {
  id        String   @id @default(cuid())
  sessionId String   @unique
  device    String?
  brandId   String?
  duration  Int      @default(0) // ms
  pageCount Int      @default(0)
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks RecordingChunk[]

  @@index([startedAt])
}

model RecordingChunk {
  id          String           @id @default(cuid())
  recordingId String
  recording   SessionRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  seq         Int
  events      Json
  createdAt   DateTime         @default(now())

  @@unique([recordingId, seq])
}
